# Default-deny: every tracked file must be explicitly allowlisted below.
**

!*/
!/.dockerignore
!/.editorconfig
!/.gitignore
!/Makefile
!/README.md
!/VERSION

!/.github/
!/.github/CODEOWNERS
!/.github/workflows/
!/.github/workflows/build.yaml

!/containers/
!/containers/Dockerfile

!/docs/
!/docs/**/*.md

!/tests/
!/tests/*.sh

!/tools/
!/tools/*.py
!/tools/*.sh
