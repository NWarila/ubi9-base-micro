# Default-deny: every tracked file must be explicitly allowlisted below.
**

!*/
!/.dockerignore
!/.editorconfig
!/.gitattributes
!/.gitignore
!/.markdownlint-cli2.jsonc
!/LICENSE
!/Makefile
!/README.md
!/VERSION

!/.github/
!/.github/CODEOWNERS
!/.github/renovate.json
!/.github/workflows/
!/.github/workflows/build.yaml
!/.github/workflows/nightly.yaml
!/.github/workflows/publish-image.yaml
!/.github/workflows/rpm-lock-refresh.yaml

!/containers/
!/containers/Dockerfile
!/containers/fips/
!/containers/fips/openssl.cnf

!/rpm-lock/
!/rpm-lock/*.txt

!/docs/
!/docs/**/*.md

!/vex/
!/vex/.gitkeep
!/vex/*.json
!/vex/README.md

!/stig/
!/stig/*.json
!/stig/*.xml

!/tests/
!/tests/*.sh

!/tools/
!/tools/*.py
!/tools/*.sh
