# Purpose: Force LF EOL per file type and export-ignore dotfiles from archives.
# Role: config
# Micro-container candidate: no (VCS attributes, not gate logic)

* text=auto eol=lf

*.json       text eol=lf
*.json5      text eol=lf
*.md         text eol=lf
*.py         text eol=lf
*.sh         text eol=lf
*.yaml       text eol=lf
*.yml        text eol=lf
.dockerignore text eol=lf
Dockerfile   text eol=lf
Makefile     text eol=lf
LICENSE      text eol=lf

.gitignore                export-ignore
.gitattributes            export-ignore
.editorconfig             export-ignore
.markdownlint-cli2.jsonc  export-ignore
