  <xccdf:Profile id="xccdf_org.nwarila.content_profile_ubi9_base_micro_stig">
    <xccdf:title>NWarila ubi9-base-micro image-scoped RHEL 9 STIG</xccdf:title>
    <xccdf:description>
      Image-rootfs tailoring for the distroless ubi9-base-micro runtime. The
      selected rules are the RHEL9 STIG controls that apply to a shipped image
      filesystem: ownership and mode of shipped identity files, valid file
      ownership, public directory permissions, UID 0 uniqueness, and additional
      SSG file-permission controls for unexpected world-writable, setuid, and
      setgid files. Host boot, kernel, init, audit daemon, PAM, SSH, mount,
      firewall, GUI, and mutable package-management controls are excluded by
      the reviewed scope justifications in stig/tailoring-justifications.json.
    </xccdf:description>

    <xccdf:select idref="xccdf_org.ssgproject.content_rule_file_permissions_etc_group" selected="true"/>
