extends: default

yaml-files:
  - "*.yaml"
  - "*.yml"
  - ".yamllint"

rules:
  document-start:
    # Repository and GitHub metadata YAML files intentionally omit document markers.
    present: false
  line-length:
    max: 160
    allow-non-breakable-words: true
    allow-non-breakable-inline-mappings: true
  truthy:
    # GitHub Actions requires the top-level "on" key.
    allowed-values: ["true", "false", "on"]
  comments:
    min-spaces-from-content: 1
