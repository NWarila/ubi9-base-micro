# Purpose: Shared editor charset/EOL/indent defaults (root = true).
# Role: config
# Micro-container candidate: no (editor config, not gate logic)
# Note: header comment must go ABOVE the `root = true` line.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab

[*.py]
indent_size = 4
